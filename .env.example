# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Database (Neon Postgres) ---
# Get from https://console.neon.tech (your project > Connection Details)
DATABASE_URL=

# --- Auth.js core ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Canonical app URL (production). Locally, defaults to http://localhost:3000.
NEXTAUTH_URL=

# --- Google OAuth provider ---
# Create at https://console.cloud.google.com (APIs & Services > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Resend (email magic-link provider) ---
# Get from https://resend.com/api-keys
AUTH_RESEND_KEY=
# Verified sender address, e.g. noreply@your-domain.com
EMAIL_FROM=
